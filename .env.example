# Fit Check runtime mode. `mock` is safe for local demos and never contacts B2 or GMI.
APP_ENV=development
PROVIDER_MODE=mock
STORAGE_MODE=local
WEB_ORIGIN=http://localhost:3000
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO

# Metadata store. SQLite is allowed only for local mock development.
# For Postgres, use: postgresql+asyncpg://fitcheck:fitcheck@localhost:5432/fitcheck
DATABASE_URL=sqlite+aiosqlite:///./.data/fit_check.db
AUTO_CREATE_SCHEMA=true

# Local mock storage (used when STORAGE_MODE=local or PROVIDER_MODE=mock).
LOCAL_MEDIA_ROOT=./local-media
PUBLIC_MEDIA_BASE_URL=http://localhost:8000/v1/media
DEMO_USER_ID=00000000-0000-0000-0000-000000000001

# Backblaze B2 S3-compatible storage. Leave empty in mock mode.
# Use a private bucket and a least-privilege application key.
B2_ENDPOINT_URL=
B2_REGION=
B2_BUCKET=
B2_KEY_ID=
B2_APP_KEY=
B2_PREFIX=fit-check
B2_PRESIGN_EXPIRES_SECONDS=900
# Server-side file-size guard. Browser clients never receive B2 credentials.
MAX_UPLOAD_BYTES=15728640

# GMI Cloud. These values are server-only; never use a NEXT_PUBLIC_ prefix.
GMI_API_KEY=
GMI_ORG_ID=
GMI_REQUEST_QUEUE_BASE_URL=https://console.gmicloud.ai/api/v1/ie/requestqueue
GMI_LLM_BASE_URL=https://api.gmi-serving.com/v1

# Intentionally blank until the account-specific capability smoke test succeeds.
GMI_VISION_MODEL=
GMI_IMAGE_MODEL=
GMI_TRYON_MODEL=
GMI_FALLBACK_IMAGE_MODEL=
GMI_GENERATION_TIMEOUT_SECONDS=180
GMI_MAX_RETRIES=2
ENABLE_PROVIDER_SMOKE_TESTS=false

# Optional fallback. Keep disabled unless a tested model is explicitly configured.
NVIDIA_API_KEY=
NVIDIA_FALLBACK_IMAGE_MODEL=

# Weather and operational controls.
WEATHER_PROVIDER=open-meteo
DAILY_GENERATION_QUOTA=3
MAX_CONCURRENT_GENERATIONS=2
SENTRY_DSN=

# Browser-only configuration. This must contain no credentials.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
